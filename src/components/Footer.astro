---
---

<footer class="site-footer">
  <div class="wrap footer-inner">
    <div class="footer-brand">
      <span class="footer-logo">pluckor</span>
      <p class="footer-tag">give an agent a real browser.</p>
    </div>
    <div class="footer-cols">
      <div class="footer-col">
        <span class="footer-head">use</span>
        <a href="/docs/getting-started/">getting started</a>
        <a href="/docs/tools/">tool reference</a>
        <a href="/docs/plk/">the plk CLI</a>
        <a href="/docs/skill/">the skill</a>
      </div>
      <div class="footer-col">
        <span class="footer-head">understand</span>
        <a href="/docs/how-it-works/">how it works</a>
        <a href="/docs/cloudflare/">cloudflare &amp; stealth</a>
        <a href="/docs/recipes/">recipes</a>
      </div>
      <div class="footer-col">
        <span class="footer-head">elsewhere</span>
        <a href="https://www.npmjs.com/package/pluckor" target="_blank" rel="noopener">npm ↗</a>
        <a href="https://github.com/pluckor/pluckor-plugin" target="_blank" rel="noopener">plugin repo ↗</a>
      </div>
    </div>
  </div>
  <div class="wrap footer-base">
    <span>MIT · a real Chrome, driven by whatever agent you point at it</span>
    <span class="footer-sig" aria-hidden="true">◉ REC</span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--line-2);
    background: var(--bg-2);
    padding-top: clamp(2.5rem, 5vw, 4rem);
    position: relative;
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-bottom: 2.5rem;
  }
  @media (min-width: 760px) {
    .footer-inner { grid-template-columns: 1.2fr 2fr; }
  }
  .footer-logo {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--amber);
    text-shadow: 0 0 18px var(--glow-soft);
  }
  .footer-tag {
    margin-top: 0.5rem;
    color: var(--fg-faint);
    font-size: 0.9rem;
  }
  .footer-cols {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 1.5rem;
  }
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .footer-head {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--fg-ghost);
    margin-bottom: 0.25rem;
  }
  .footer-col a {
    font-size: 0.88rem;
    color: var(--fg-dim);
    transition: color 0.2s;
  }
  .footer-col a:hover { color: var(--amber-hi); }
  .footer-base {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: 1.25rem;
    border-top: 1px solid var(--line-2);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--fg-ghost);
  }
  .footer-sig {
    color: var(--block);
    animation: rec 2.4s ease-in-out infinite;
  }
  @keyframes rec {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }
</style>
